# Preset: minimal-iot
# IoT / 低资源场景：只保留 web 对话 + RPC，最小体积 profile，砍掉所有可选子系统。
# 加载：nemesis-config load minimal-iot

[features]
channels-web = true
channels-webhook = false
channels-rpc = true
channels-telegram = false
channels-discord = false
channels-slack = false
channels-feishu = false
channels-dingtalk = false
channels-onebot = false
channels-tencent = false
channels-email = false
channels-matrix = false
channels-irc = false
channels-signal = false
channels-mastodon = false
channels-bluesky = false
channels-whatsapp = false
migrate = false
devices = false
desktop = false
health = false
heartbeat = false
auth = false
voice = false
cluster = false
forge = false
# ── 全部 4 个 Class C 内核 phase 已完成（forge/memory/workflow/security）。无过渡 pin。
memory = false
workflow = false
security = false
sandbox = false
usage = false

[enums]
build-profile = "iotsmall"
