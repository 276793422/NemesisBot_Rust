# Preset: desktop
# 桌面全功能：默认三通道 + 可选子系统，标准 release profile。
# 加载：nemesis-config load desktop

[features]
channels-web = true
channels-webhook = true
channels-rpc = true
channels-telegram = false
channels-discord = false
channels-slack = false
channels-feishu = false
channels-dingtalk = false
channels-onebot = false
channels-tencent = false
channels-email = false
channels-matrix = false
channels-irc = false
channels-signal = false
channels-mastodon = false
channels-bluesky = false
channels-whatsapp = false
migrate = true
devices = true
desktop = true
health = true
heartbeat = true
auth = true
voice = true
cluster = true
forge = true
memory = true
workflow = true
security = true

[enums]
build-profile = "release"
