{
  "default_action": "allow",
  "log_all_operations": true,
  "log_denials_only": false,
  "approval_timeout_seconds": 300,
  "max_pending_requests": 100,
  "audit_log_retention_days": 90,
  "audit_log_file_enabled": true,
  "synchronous_mode": false,
  "file_rules": {
    "read": [
      {
        "pattern": "C:/Windows/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Program Files/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Program Files (x86)/**",
        "action": "deny"
      },
      {
        "pattern": "C:/ProgramData/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Users/*/AppData/Roaming/Microsoft/Protect/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Users/*/AppData/Local/Microsoft/Credentials/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Windows/System32/config/**",
        "action": "deny"
      }
    ],
    "write": [
      {
        "pattern": "C:/Windows/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Program Files/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Program Files (x86)/**",
        "action": "deny"
      },
      {
        "pattern": "C:/ProgramData/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Users/*/AppData/Roaming/Microsoft/Protect/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Boot/**",
        "action": "deny"
      },
      {
        "pattern": "C:/EFI/**",
        "action": "deny"
      }
    ],
    "delete": [
      {
        "pattern": "C:/Windows/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Program Files/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Program Files (x86)/**",
        "action": "deny"
      },
      {
        "pattern": "C:/ProgramData/**",
        "action": "deny"
      },
      {
        "pattern": "C:/Boot/**",
        "action": "deny"
      }
    ]
  },
  "directory_rules": {
    "read": [
      {
        "pattern": "/workspace/**",
        "action": "allow"
      }
    ],
    "create": [
      {
        "pattern": "/workspace/**",
        "action": "allow"
      }
    ],
    "delete": [
      {
        "pattern": "/workspace/tmp/**",
        "action": "allow"
      }
    ]
  },
  "process_rules": {
    "exec": [
      {
        "pattern": "git *",
        "action": "allow"
      },
      {
        "pattern": "npm *",
        "action": "allow"
      },
      {
        "pattern": "go run *",
        "action": "allow"
      },
      {
        "pattern": "python *",
        "action": "allow"
      },
      {
        "pattern": "node *",
        "action": "allow"
      },
      {
        "pattern": "rm -rf *",
        "action": "deny"
      },
      {
        "pattern": "format *",
        "action": "deny"
      },
      {
        "pattern": "del *",
        "action": "ask"
      },
      {
        "pattern": "rmdir *",
        "action": "ask"
      }
    ],
    "spawn": [
      {
        "pattern": "*",
        "action": "ask"
      }
    ],
    "kill": [
      {
        "pattern": "*",
        "action": "deny"
      }
    ],
    "suspend": [
      {
        "pattern": "*",
        "action": "deny"
      }
    ]
  },
  "network_rules": {
    "request": [
      {
        "pattern": "*.github.com",
        "action": "allow"
      },
      {
        "pattern": "*.openai.com",
        "action": "allow"
      },
      {
        "pattern": "*.anthropic.com",
        "action": "allow"
      }
    ],
    "download": [
      {
        "pattern": "*",
        "action": "ask"
      }
    ],
    "upload": [
      {
        "pattern": "*",
        "action": "ask"
      }
    ]
  },
  "hardware_rules": {
    "i2c": [
      {
        "pattern": "*",
        "action": "allow"
      }
    ],
    "spi": [
      {
        "pattern": "*",
        "action": "allow"
      }
    ],
    "gpio": [
      {
        "pattern": "*",
        "action": "allow"
      }
    ]
  },
  "registry_rules": {
    "read": [
      {
        "pattern": "HKEY_CURRENT_USER/**",
        "action": "allow"
      },
      {
        "pattern": "HKEY_LOCAL_MACHINE/**",
        "action": "ask"
      }
    ],
    "write": [
      {
        "pattern": "HKEY_CURRENT_USER/**",
        "action": "ask"
      },
      {
        "pattern": "HKEY_LOCAL_MACHINE/**",
        "action": "deny"
      }
    ],
    "delete": [
      {
        "pattern": "*",
        "action": "deny"
      }
    ]
  }
}
