{
  "default_action": "allow",
  "log_all_operations": true,
  "log_denials_only": false,
  "approval_timeout_seconds": 300,
  "max_pending_requests": 100,
  "audit_log_retention_days": 90,
  "audit_log_file_enabled": true,
  "synchronous_mode": false,
  "file_rules": {
    "read": [
      {
        "pattern": "/etc/shadow",
        "action": "deny"
      },
      {
        "pattern": "/etc/sudoers",
        "action": "deny"
      },
      {
        "pattern": "/etc/passwd",
        "action": "ask"
      },
      {
        "pattern": "/usr/bin/**",
        "action": "deny"
      },
      {
        "pattern": "/bin/**",
        "action": "deny"
      },
      {
        "pattern": "/sbin/**",
        "action": "deny"
      },
      {
        "pattern": "/usr/sbin/**",
        "action": "deny"
      },
      {
        "pattern": "/root/**",
        "action": "deny"
      },
      {
        "pattern": "/boot/**",
        "action": "deny"
      },
      {
        "pattern": "/sys/**",
        "action": "deny"
      }
    ],
    "write": [
      {
        "pattern": "/etc/**",
        "action": "deny"
      },
      {
        "pattern": "/usr/**",
        "action": "deny"
      },
      {
        "pattern": "/bin/**",
        "action": "deny"
      },
      {
        "pattern": "/sbin/**",
        "action": "deny"
      },
      {
        "pattern": "/boot/**",
        "action": "deny"
      },
      {
        "pattern": "/root/**",
        "action": "deny"
      },
      {
        "pattern": "/sys/**",
        "action": "deny"
      },
      {
        "pattern": "/lib/**",
        "action": "deny"
      }
    ],
    "delete": [
      {
        "pattern": "/etc/**",
        "action": "deny"
      },
      {
        "pattern": "/usr/**",
        "action": "deny"
      },
      {
        "pattern": "/bin/**",
        "action": "deny"
      },
      {
        "pattern": "/sbin/**",
        "action": "deny"
      },
      {
        "pattern": "/boot/**",
        "action": "deny"
      },
      {
        "pattern": "/root/**",
        "action": "deny"
      }
    ]
  },
  "directory_rules": {
    "read": [
      {
        "pattern": "/workspace/**",
        "action": "allow"
      }
    ],
    "create": [
      {
        "pattern": "/workspace/**",
        "action": "allow"
      }
    ],
    "delete": [
      {
        "pattern": "/workspace/tmp/**",
        "action": "allow"
      }
    ]
  },
  "process_rules": {
    "exec": [
      {
        "pattern": "git *",
        "action": "allow"
      },
      {
        "pattern": "npm *",
        "action": "allow"
      },
      {
        "pattern": "go run *",
        "action": "allow"
      },
      {
        "pattern": "python *",
        "action": "allow"
      },
      {
        "pattern": "node *",
        "action": "allow"
      },
      {
        "pattern": "rm -rf /*",
        "action": "deny"
      },
      {
        "pattern": "rm -rf /",
        "action": "deny"
      },
      {
        "pattern": "*sudo*",
        "action": "deny"
      },
      {
        "pattern": "systemctl *",
        "action": "ask"
      },
      {
        "pattern": "service *",
        "action": "ask"
      },
      {
        "pattern": "apt *",
        "action": "ask"
      },
      {
        "pattern": "yum *",
        "action": "ask"
      },
      {
        "pattern": "dnf *",
        "action": "ask"
      },
      {
        "pattern": "pacman *",
        "action": "ask"
      }
    ],
    "spawn": [
      {
        "pattern": "*",
        "action": "ask"
      }
    ],
    "kill": [
      {
        "pattern": "*",
        "action": "deny"
      }
    ],
    "suspend": [
      {
        "pattern": "*",
        "action": "deny"
      }
    ]
  },
  "network_rules": {
    "request": [
      {
        "pattern": "*.github.com",
        "action": "allow"
      },
      {
        "pattern": "*.openai.com",
        "action": "allow"
      },
      {
        "pattern": "*.anthropic.com",
        "action": "allow"
      }
    ],
    "download": [
      {
        "pattern": "*",
        "action": "ask"
      }
    ],
    "upload": [
      {
        "pattern": "*",
        "action": "ask"
      }
    ]
  },
  "hardware_rules": {
    "i2c": [
      {
        "pattern": "*",
        "action": "allow"
      }
    ],
    "spi": [
      {
        "pattern": "*",
        "action": "allow"
      }
    ],
    "gpio": [
      {
        "pattern": "*",
        "action": "allow"
      }
    ]
  }
}
